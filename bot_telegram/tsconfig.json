{
  "compilerOptions": {
    // 1. Defina onde estão seus fontes e onde será a saída
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "nodenext",
    "target": "esnext",
    
    // 2. Remova ou comente sourceMap e declaration para produção (opcional)
    // Isso economiza mais alguns MBs na imagem final
    "sourceMap": false,
    "declaration": false,

    "strict": true,
    "skipLibCheck": true,
    "moduleDetection": "force",
    "verbatimModuleSyntax": true,
    "isolatedModules": true
  },
  "include": ["src/**/*"]
}