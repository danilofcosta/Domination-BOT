generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////////////////////////////////////
// SESSION (grammy)
//////////////////////////////////////////////////////////

model Session {
  key  String @id
  data Json
}

//////////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////////

enum Language {
  PT
  EN
}

enum MediaType {
  IMAGE_URL
  IMAGE_FILEID
  VIDEO_URL
  VIDEO_FILEID
}

enum ProfileType {
  SUPREME
  SUPER_ADMIN
  ADMIN
  MODERATOR
  USER
  BANNED
}

enum SourceType {
  ANIME
  GAME
  MANGA
  MOVIE
}

//////////////////////////////////////////////////////////
// WAIFUS
//////////////////////////////////////////////////////////

model CharacterWaifu {
  id         Int    @id @default(autoincrement())
  name       String @db.VarChar(100)
  origem     String @db.VarChar(100)

  sourceType SourceType @default(ANIME)

  mediaType MediaType?
  media     String?

  extras Json?
  slug   String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  popularity Int @default(0)

  linkweb String?
  linkwebExpiresAt DateTime?

  events   WaifuEvent[]
  rarities WaifuRarity[]

  favoritedBy User[] @relation("FavoriteWaifu")
  collections WaifuCollection[]

  @@index([name, origem])
}

//////////////////////////////////////////////////////////
// HUSBANDOS
//////////////////////////////////////////////////////////

model CharacterHusbando {
  id         Int    @id @default(autoincrement())
  name       String @db.VarChar(100)
  origem     String @db.VarChar(100)

  sourceType SourceType @default(ANIME)

  mediaType MediaType?
  media     String?

  slug   String @unique
  extras Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  popularity Int @default(0)

  linkweb String?
  linkwebExpiresAt DateTime?

  events   HusbandoEvent[]
  rarities HusbandoRarity[]

  favoritedBy User[] @relation("FavoriteHusbando")
  collections HusbandoCollection[]

  @@index([name, origem])
}

//////////////////////////////////////////////////////////
// EVENTS
//////////////////////////////////////////////////////////

model Event {
  id          Int    @id @default(autoincrement())
  code        String @unique
  name        String
  emoji       String
  description String?
   emoji_id    String?

  waifus    WaifuEvent[]
  husbandos HusbandoEvent[]
}

//////////////////////////////////////////////////////////
// RARITIES
//////////////////////////////////////////////////////////

model Rarity {
  id          Int    @id @default(autoincrement())
  code        String @unique
  name        String
  emoji       String
  description String?
 emoji_id    String?
  waifus    WaifuRarity[]
  husbandos HusbandoRarity[]
}

//////////////////////////////////////////////////////////
// RELATIONS
//////////////////////////////////////////////////////////

model WaifuEvent {
  characterId Int
  eventId     Int

  character CharacterWaifu @relation(fields: [characterId], references: [id], onDelete: Cascade)
  event     Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@id([characterId, eventId])
}

model HusbandoEvent {
  characterId Int
  eventId     Int

  character CharacterHusbando @relation(fields: [characterId], references: [id], onDelete: Cascade)
  event     Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@id([characterId, eventId])
}

model WaifuRarity {
  characterId Int
  rarityId    Int

  character CharacterWaifu @relation(fields: [characterId], references: [id], onDelete: Cascade)
  rarity    Rarity         @relation(fields: [rarityId], references: [id], onDelete: Cascade)

  @@id([characterId, rarityId])
}

model HusbandoRarity {
  characterId Int
  rarityId    Int

  character CharacterHusbando @relation(fields: [characterId], references: [id], onDelete: Cascade)
  rarity    Rarity            @relation(fields: [rarityId], references: [id], onDelete: Cascade)

  @@id([characterId, rarityId])
}

//////////////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////////////

model User {
  id         Int    @id @default(autoincrement())
  telegramId BigInt @unique

  // favoritos
  favoriteWaifuId Int?
  favoriteWaifu   CharacterWaifu? @relation("FavoriteWaifu", fields: [favoriteWaifuId], references: [id])

  favoriteHusbandoId Int?
  favoriteHusbando   CharacterHusbando? @relation("FavoriteHusbando", fields: [favoriteHusbandoId], references: [id])

  // configs
  waifuConfig    Json?
  husbandoConfig Json?
  telegramData   Json?

  // economia
  coins Int @default(0)

  // relações
  waifuCollection    WaifuCollection[]
  husbandoCollection HusbandoCollection[]

  profileType ProfileType @default(USER)
  language    Language    @default(PT)
}

//////////////////////////////////////////////////////////
// COLLECTIONS
//////////////////////////////////////////////////////////

model WaifuCollection {
  id Int @id @default(autoincrement())

  userId      BigInt
  characterId Int

  user      User           @relation(fields: [userId], references: [telegramId], onDelete: Cascade)
  character CharacterWaifu @relation(fields: [characterId], references: [id], onDelete: Cascade)

  count Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, characterId])
  @@index([userId])
}

model HusbandoCollection {
  id Int @id @default(autoincrement())

  userId      BigInt
  characterId Int

  user      User              @relation(fields: [userId], references: [telegramId], onDelete: Cascade)
  character CharacterHusbando @relation(fields: [characterId], references: [id], onDelete: Cascade)

  count Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, characterId])
  @@index([userId])
}